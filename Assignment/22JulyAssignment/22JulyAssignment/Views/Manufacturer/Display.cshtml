@model _22JulyAssignment.Models.Manufacturer

<h2>Manufacturer Details</h2>

<table class="table table-bordered">

    <tr>
        <th>Manufacturer Name</th>
        <td>@Model.Name</td>
    </tr>

    <tr>
        <th>Country</th>
        <td>@Model.Country</td>
    </tr>

    <tr>
        <th>Contact Number</th>
        <td>@Model.ContactNumber</td>
    </tr>

    <tr>
        <th>Email Address</th>
        <td>@Model.Email</td>
    </tr>

</table>