@model List<Stationary>
<h3> Stationary Item List </h3>
<table border="1" cellspacing="10">
    <tr>
        <th> ID</th>
        <th> Name</th>

        <th> Price</th>
        <th>Quantity</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ID</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.Quantity</td>
        </tr>
    }
</table>
<br />
<a href="@Url.Action("Logout", "Home")">Logout</a>


