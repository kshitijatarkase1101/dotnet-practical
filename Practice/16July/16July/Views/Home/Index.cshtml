@model List<_16July.Models.Student>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome To Student Portal</h1>
   
</div>
      <table border="2" cellpadding="10">
          <tr>
              <th>ID</th>
        <th>NAME</th>

        <th>AGE</th>
        <th>COURSE</th>
        <th>QUALIFICATION</th>
        <th>GENDER</th>


          </tr>
          @foreach(var item in Model){
              <tr>
                  <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Age</td>
            <td>@item.Course</td>
            <td>@item.Qualification</td>
            <td>@item.Gender</td>
              </tr>
          }
      </table>
